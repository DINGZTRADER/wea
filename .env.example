# Set real values in your host's environment-variable UI.
# Do not commit real secrets or placeholder values that you also use in hosting.
GEMINI_API_KEY=
SESSION_SECRET=

# Optional for production. If omitted, the app uses data/wea.local.json for local development.
DATABASE_URL=
DATABASE_SSL=
DATABASE_POOL_SIZE=

# Optional model overrides.
GEMINI_DECISION_MODEL=
GEMINI_CHAT_MODEL=
GEMINI_TTS_MODEL=
